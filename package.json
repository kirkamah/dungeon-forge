{
  "name": "dungeon-forge",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "author": "Kirkamah (no harm org)",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "cross-env DF_DEV_URL=http://127.0.0.1:5173 electron .",
    "dist": "vite build && electron-builder --win nsis",
    "dist:trial": "cross-env VITE_TRIAL=1 vite build && electron-builder --win nsis -c.nsis.artifactName=DungeonForge-Trial-Setup.exe"
  },
  "build": {
    "appId": "org.noharm.dungeonforge",
    "productName": "Dungeon Forge",
    "copyright": "© 2026 Kirkamah · no harm org",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "app-icon.ico",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "app-icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Dungeon Forge",
      "artifactName": "DungeonForge-Setup-${version}.exe"
    },
    "afterPack": "scripts/afterPack.cjs",
    "mac": {
      "icon": "Logo_Dungeon_Forge.png",
      "category": "public.app-category.role-playing-games",
      "minimumSystemVersion": "11.0",
      "identity": null,
      "target": [
        { "target": "zip", "arch": "universal" }
      ],
      "artifactName": "DungeonForge-mac.${ext}"
    }
  },
  "dependencies": {
    "idb": "^8.0.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "seedrandom": "^3.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "vite": "^8.0.12"
  }
}
